---
import Layout from "../../layouts/Layout.astro";
import ImgPb from "../../components/ImgPb.astro";
import CardConseil from "../../components/CardConseil.astro";
import type { ConseilResponse } from "../../pocketbase-types";

const { id } = Astro.params;
const user = Astro.locals.pb.authStore.model;

const conseil = await Astro.locals.pb
    .collection("conseil")
    .getOne<ConseilResponse>(id || "");

// Conseils similaires (exclure le courant)
const conseilsSimilaires = await Astro.locals.pb
    .collection("conseil")
    .getFullList<ConseilResponse>({
        sort: "-date_publication",
        filter: `id != "${id}" && statut = "publie"`,
        limit: 3,
    });
---

<Layout titre={conseil.titre}>
    <section class="w-full bg-slate-50">
        {/* HERO BANNER */}
        <div class="relative h-64 w-full overflow-hidden bg-slate-300 sm:h-80">
            <ImgPb
                record={conseil}
                field="image"
                alt={conseil.titre}
                classPicture="h-full w-full"
                classImg="h-full w-full object-cover"
                thumb="1200x400"
            />
            <div
                class="absolute inset-0 bg-linear-to-t from-black/60 to-transparent"
            >
            </div>

            <div class="absolute bottom-0 left-0 right-0 p-6 sm:p-8">
                <div class="container mx-auto">
                    <span
                        class="mb-4 inline-block rounded-full bg-emerald-600 px-4 py-1 text-xs font-semibold text-white"
                    >
                        Conseil
                    </span>
                    <h1 class="mb-4 text-3xl font-bold text-white sm:text-4xl">
                        {conseil.titre}
                    </h1>
                    <div class="flex items-center gap-4">
                        <div>
                            <p class="text-sm font-semibold text-white">
                                Dr. {conseil.auteur_id || "Expert"}
                            </p>
                            <p class="text-xs text-slate-300">
                                {
                                    conseil.date_publication
                                        ? new Date(
                                              conseil.date_publication,
                                          ).toLocaleDateString("fr-FR", {
                                              year: "numeric",
                                              month: "long",
                                              day: "numeric",
                                          })
                                        : ""
                                }
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="container mx-auto px-6 py-12">
            {/* HEADER WITH EDIT BUTTON */}
            <div class="mb-8 flex items-center justify-between">
                <div></div>
                {
                    user &&
                        user.id === conseil.auteur_id &&
                        user.role?.includes("pro") && (
                            <a
                                href={`/conseils/edit/${conseil.id}`}
                                class="inline-flex items-center gap-2 rounded-lg bg-slate-200 px-3 py-1.5 text-xs font-semibold text-slate-700 transition-all hover:bg-slate-300"
                            >
                                ✏️ Éditer
                            </a>
                        )
                }
            </div>

            {/* CONTENU */}
            <article class="prose prose-sm max-w-3xl lg:prose-base">
                <div class="mb-12 text-slate-700" set:html={conseil.contenu} />
            </article>

            {/* MOTS-CLÉS */}
            {
                conseil.titre && (
                    <div class="mb-12 max-w-3xl border-t pt-8">
                        <h3 class="mb-4 font-semibold text-slate-900">
                            Mots-clés :
                        </h3>
                        <div class="flex flex-wrap gap-2">
                            {conseil.titre
                                .split(/[,\s]+/)
                                .slice(0, 5)
                                .map((word) => (
                                    <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-medium text-emerald-700">
                                        {word.trim()}
                                    </span>
                                ))}
                        </div>
                    </div>
                )
            }
        </div>

        {/* CONSEILS SIMILAIRES */}
        {
            conseilsSimilaires.length > 0 && (
                <div class="border-t bg-white">
                    <div class="container mx-auto px-6 py-12">
                        <h2 class="mb-8 text-2xl font-bold text-slate-900">
                            Conseils similaires
                        </h2>
                        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                            {conseilsSimilaires.map((item) => (
                                <CardConseil conseil={item} />
                            ))}
                        </div>
                    </div>
                </div>
            )
        }
    </section>
</Layout>
