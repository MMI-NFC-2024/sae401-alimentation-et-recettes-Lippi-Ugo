---
import LinkRecette from "../../components/LinkRecette.astro";
import LinkProduitSponsorise from "../../components/LinkProduitSponsorise.astro";
import Layout from "../../layouts/Layout.astro";
import {
    type CategorieRecetteResponse,
    type ProduitSponsoriseResponse,
    type RecetteCategorieResponse,
    type RecetteRegimeCompatibleResponse,
    type RecetteResponse,
    type RegimeAlimentaireResponse,
} from "../../pocketbase-types";

const [
    toutesRecettes,
    produitsSponsorises,
    categoriesRef,
    liensRecetteCategorie,
    regimesRef,
    liensRecetteRegime,
] = await Promise.all([
    Astro.locals.pb.collection("recette").getFullList<RecetteResponse>(),
    Astro.locals.pb
        .collection("produit_sponsorise")
        .getFullList<ProduitSponsoriseResponse>(),
    Astro.locals.pb
        .collection("categorie_recette")
        .getFullList<CategorieRecetteResponse>(),
    Astro.locals.pb
        .collection("recette_categorie")
        .getFullList<RecetteCategorieResponse>(),
    Astro.locals.pb
        .collection("regime_alimentaire")
        .getFullList<RegimeAlimentaireResponse>(),
    Astro.locals.pb
        .collection("recette_regime_compatible")
        .getFullList<RecetteRegimeCompatibleResponse>(),
]);

const recettes = [...toutesRecettes].sort((a, b) => a.nom.localeCompare(b.nom));

const categorieParId = new Map(
    categoriesRef.map((item) => [item.id, item.nom]),
);
const regimeParId = new Map(regimesRef.map((item) => [item.id, item.nom]));

const categoriesParRecette = liensRecetteCategorie.reduce(
    (acc, lien) => {
        const categorie = categorieParId.get(lien.categorie_id);
        if (!categorie) return acc;
        if (!acc[lien.recette_id]) acc[lien.recette_id] = [];
        acc[lien.recette_id].push(categorie);
        return acc;
    },
    {} as Record<string, string[]>,
);

const regimesParRecette = liensRecetteRegime.reduce(
    (acc, lien) => {
        const regime = regimeParId.get(lien.regime_id);
        if (!regime) return acc;
        if (!acc[lien.recette_id]) acc[lien.recette_id] = [];
        acc[lien.recette_id].push(regime);
        return acc;
    },
    {} as Record<string, string[]>,
);

const categorieDeRecette = (recette: RecetteResponse) =>
    categoriesParRecette[recette.id]?.[0] || recette.categorie || "";

const regimesDeRecette = (recette: RecetteResponse) => {
    const valeurs = regimesParRecette[recette.id] || [];
    if (valeurs.length > 0) return valeurs;
    return recette.regime ? [recette.regime] : [];
};

const recettesAvecRelations = recettes.map((recette) => ({
    recette,
    categorie: categorieDeRecette(recette),
    regimes: regimesDeRecette(recette),
}));

const produitsSponsorisesAffichees = produitsSponsorises.slice(0, 3);

const categoriesDisponibles = [
    ...new Set(
        recettesAvecRelations
            .map((item) => item.categorie)
            .filter((value): value is string => Boolean(value)),
    ),
].sort((a, b) => a.localeCompare(b));

const difficultesDisponibles = [
    ...new Set(
        toutesRecettes
            .map((recette) => recette.difficulte)
            .filter(
                (value): value is NonNullable<RecetteResponse["difficulte"]> =>
                    Boolean(value),
            ),
    ),
].sort((a, b) => a.localeCompare(b));

const tagsRegimes = [
    ...new Set(
        recettesAvecRelations.flatMap((item) => item.regimes).filter(Boolean),
    ),
].sort((a, b) => a.localeCompare(b));
---

<Layout titre="Recettes">
    <section class="container mx-auto px-6 py-10 lg:py-14">
        <div class="mb-10">
            <h1 class="mb-2 text-4xl font-bold text-slate-900">
                Recettes Saines
            </h1>

            <p class="mb-5 text-(--color-text-muted)">
                Decouvrez des recettes equilibrees avec informations
                nutritionnelles et calculateur de portions.
            </p>

            <form
                id="filtres-recettes"
                class="rounded-2xl border border-slate-200 bg-white p-4"
            >
                <div class="grid grid-cols-1 gap-3 md:grid-cols-3">
                    <input
                        type="text"
                        id="recherche-recette"
                        placeholder="Rechercher une recette..."
                        class="w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-700 outline-none focus:border-(--color-primary)"
                    />

                    <select
                        id="categorie-recette"
                        class="w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-600 outline-none focus:border-(--color-primary)"
                    >
                        <option value="">Toutes les categories</option>
                        {
                            categoriesDisponibles.map((optionCategorie) => (
                                <option value={optionCategorie}>
                                    {optionCategorie}
                                </option>
                            ))
                        }
                    </select>

                    <select
                        id="difficulte-recette"
                        class="w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-600 outline-none focus:border-(--color-primary)"
                    >
                        <option value="">Toutes les difficultes</option>
                        {
                            difficultesDisponibles.map((optionDifficulte) => (
                                <option value={optionDifficulte}>
                                    {optionDifficulte}
                                </option>
                            ))
                        }
                    </select>
                </div>

                <div class="mt-3 flex flex-wrap gap-2">
                    {
                        tagsRegimes.map((tag) => (
                            <button
                                type="button"
                                class="regime-tag rounded-full border border-slate-200 bg-slate-50 px-2 py-0.5 text-xs text-slate-600 transition hover:bg-slate-100 hover:text-slate-700"
                                data-regime={tag}
                            >
                                {tag}
                            </button>
                        ))
                    }
                </div>

                <div class="mt-3 flex items-center justify-between gap-3">
                    <p id="compteur-recettes" class="text-xs text-slate-500">
                        {recettesAvecRelations.length} recettes trouvees
                    </p>

                    <div class="flex items-center gap-2">
                        <button
                            id="reset-filtres"
                            type="button"
                            class="rounded-md border border-slate-200 px-3 py-1.5 text-xs text-slate-600 hover:bg-slate-100"
                        >
                            Reinitialiser
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <div
            id="grille-recettes"
            class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3"
        >
            {
                recettesAvecRelations.map((item) => (
                    <div
                        class="recette-item"
                        data-nom={item.recette.nom.toLowerCase()}
                        data-categorie={item.categorie}
                        data-difficulte={item.recette.difficulte || ""}
                        data-regimes={item.regimes.join("|")}
                    >
                        <LinkRecette recette={item.recette} />
                    </div>
                ))
            }
        </div>

        {
            produitsSponsorisesAffichees.length > 0 && (
                <section class="mt-14 border-t border-slate-200 pt-10">
                    <h2 class="mb-6 text-slate-900">
                        Pour cuisiner comme un chef
                    </h2>

                    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
                        {produitsSponsorisesAffichees.map((produit) => (
                            <LinkProduitSponsorise produit={produit} />
                        ))}
                    </div>
                </section>
            )
        }

        {
            Astro.locals.pb.authStore.isValid && (
                <a
                    href="/recettes"
                    class="mt-8 inline-flex items-center gap-2 rounded-lg bg-(--color-primary-dark) px-6 py-3 font-semibold text-white shadow-lg transition-all hover:bg-(--color-primary-hover) hover:shadow-xl"
                >
                    <svg
                        class="h-5 w-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 4v16m8-8H4"
                        />
                    </svg>
                    Ajouter une nouvelle recette
                </a>
            )
        }
    </section>

    <script>
        const formFiltres = document.getElementById("filtres-recettes");
        const inputRecherche = document.getElementById("recherche-recette");
        const selectCategorie = document.getElementById("categorie-recette");
        const selectDifficulte = document.getElementById("difficulte-recette");
        const boutonReset = document.getElementById("reset-filtres");
        const grilleRecettes = document.getElementById("grille-recettes");
        const compteurRecettes = document.getElementById("compteur-recettes");
        const boutonsRegime = document.querySelectorAll(".regime-tag");

        let regimeActif = "";

        const rafraichirEtatRegimes = () => {
            boutonsRegime.forEach((bouton) => {
                if (!(bouton instanceof HTMLButtonElement)) return;

                const isActif = bouton.dataset.regime === regimeActif;
                bouton.classList.toggle("bg-(--color-primary-dark)", isActif);
                bouton.classList.toggle("text-white", isActif);
                bouton.classList.toggle(
                    "border-(--color-primary-dark)",
                    isActif,
                );
                bouton.classList.toggle(
                    "hover:bg-(--color-primary-hover)",
                    isActif,
                );
                bouton.classList.toggle("hover:text-white", isActif);
                bouton.classList.toggle("bg-slate-50", !isActif);
                bouton.classList.toggle("text-slate-600", !isActif);
                bouton.classList.toggle("border-slate-200", !isActif);
                bouton.classList.toggle("hover:bg-slate-100", !isActif);
                bouton.classList.toggle("hover:text-slate-700", !isActif);
            });
        };

        const filtrerRecettes = () => {
            if (!(grilleRecettes instanceof HTMLDivElement)) return;

            const terme =
                inputRecherche instanceof HTMLInputElement
                    ? inputRecherche.value.trim().toLowerCase()
                    : "";
            const categorie =
                selectCategorie instanceof HTMLSelectElement
                    ? selectCategorie.value
                    : "";
            const difficulte =
                selectDifficulte instanceof HTMLSelectElement
                    ? selectDifficulte.value
                    : "";

            const items = grilleRecettes.querySelectorAll(".recette-item");
            let visibles = 0;

            items.forEach((item) => {
                if (!(item instanceof HTMLDivElement)) return;

                const nom = item.dataset.nom || "";
                const itemCategorie = item.dataset.categorie || "";
                const itemDifficulte = item.dataset.difficulte || "";
                const itemRegimes = item.dataset.regimes || "";

                const matchNom = !terme || nom.includes(terme);
                const matchCategorie =
                    !categorie || itemCategorie === categorie;
                const matchDifficulte =
                    !difficulte || itemDifficulte === difficulte;
                const matchRegime =
                    !regimeActif ||
                    itemRegimes
                        .split("|")
                        .filter(Boolean)
                        .includes(regimeActif);
                const visible =
                    matchNom &&
                    matchCategorie &&
                    matchDifficulte &&
                    matchRegime;

                item.style.display = visible ? "block" : "none";

                if (visible) visibles += 1;
            });

            if (compteurRecettes instanceof HTMLParagraphElement) {
                compteurRecettes.textContent = `${visibles} recettes trouvees`;
            }
        };

        if (formFiltres instanceof HTMLFormElement) {
            formFiltres.addEventListener("submit", (event) => {
                event.preventDefault();
            });

            let timer = 0;
            if (inputRecherche instanceof HTMLInputElement) {
                inputRecherche.addEventListener("input", () => {
                    clearTimeout(timer);
                    timer = window.setTimeout(() => filtrerRecettes(), 220);
                });
            }

            if (selectCategorie instanceof HTMLSelectElement) {
                selectCategorie.addEventListener("change", () =>
                    filtrerRecettes(),
                );
            }

            if (selectDifficulte instanceof HTMLSelectElement) {
                selectDifficulte.addEventListener("change", () =>
                    filtrerRecettes(),
                );
            }

            boutonsRegime.forEach((bouton) => {
                if (!(bouton instanceof HTMLButtonElement)) return;

                bouton.addEventListener("click", () => {
                    const valeur = bouton.dataset.regime || "";
                    regimeActif = regimeActif === valeur ? "" : valeur;
                    rafraichirEtatRegimes();
                    filtrerRecettes();
                });
            });

            if (boutonReset instanceof HTMLButtonElement) {
                boutonReset.addEventListener("click", () => {
                    if (inputRecherche instanceof HTMLInputElement)
                        inputRecherche.value = "";
                    if (selectCategorie instanceof HTMLSelectElement)
                        selectCategorie.value = "";
                    if (selectDifficulte instanceof HTMLSelectElement)
                        selectDifficulte.value = "";
                    regimeActif = "";
                    rafraichirEtatRegimes();
                    filtrerRecettes();
                });
            }
        }
    </script>
</Layout>
