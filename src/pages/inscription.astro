                <form method="post" class="space-y-5">
                    {/* PRENOM & NOM */}
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label
                                for="prenom"
                                class="mb-2 block text-sm font-semibold text-slate-700"
                            >
                                Prénom
                            </label>
                            <div class="relative">
                                <svg
                                    class="absolute left-3 top-2.5 h-5 w-5 text-slate-400"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                                    >
                                    </path>
                                </svg>
                                <input
                                    type="text"
                                    id="prenom"
                                    name="prenom"
                                    placeholder="Jean"
                                    required
                                    class="w-full rounded-lg bg-slate-100 py-2 pl-10 pr-4 text-slate-900 placeholder-slate-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-600"
                                />
                            </div>
                        </div>
                        <div>
                            <label
                                for="nom"
                                class="mb-2 block text-sm font-semibold text-slate-700"
                            >
                                Nom
                            </label>
                            <div class="relative">
                                <svg
                                    class="absolute left-3 top-2.5 h-5 w-5 text-slate-400"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                                    >
                                    </path>
                                </svg>
                                <input
                                    type="text"
                                    id="nom"
                                    name="nom"
                                    placeholder="Dupont"
                                    required
                                    class="w-full rounded-lg bg-slate-100 py-2 pl-10 pr-4 text-slate-900 placeholder-slate-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-600"
                                />
                            </div>
                        </div>
                    </div>

                    {/* EMAIL */}
                    <div>
                        <label
                            for="email"
                            class="mb-2 block text-sm font-semibold text-slate-700"
                        >
                            Email
                        </label>
                        <div class="relative">
                            <svg
                                class="absolute left-3 top-2.5 h-5 w-5 text-slate-400"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                >
                                </path>
                            </svg>
                            <input
                                type="email"
                                id="email"
                                name="email"
                                placeholder="votre@email.fr"
                                required
                                class="w-full rounded-lg bg-slate-100 py-2 pl-10 pr-4 text-slate-900 placeholder-slate-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-600"
                            />
