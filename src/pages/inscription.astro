                            />
                        </div>
                    </div>

                    {/* PASSWORD CONFIRM */}
                    <div>
                        <label
                            for="passwordConfirm"
                            class="mb-2 block text-sm font-semibold text-slate-700"
                        >
                            Confirmer le mot de passe
                        </label>
                        <div class="relative">
                            <svg
                                class="absolute left-3 top-2.5 h-5 w-5 text-slate-400"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                                >
                                </path>
                            </svg>
                            <input
                                type="password"
                                id="passwordConfirm"
                                name="passwordConfirm"
                                placeholder="••••••••"
                                required
                                minlength="5"
                                class="w-full rounded-lg bg-slate-100 py-2 pl-10 pr-4 text-slate-900 placeholder-slate-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-600"
                            />
                        </div>
                    </div>

                    {/* ACCOUNT TYPE */}
                    <div>
                        <label
                            class="mb-3 block text-sm font-semibold text-slate-700"
                        >
                            Type de compte
                        </label>
                        <div class="grid grid-cols-2 gap-4">
                            <label class="relative cursor-pointer">
                                <input
                                    type="radio"
                                    name="role"
                                    value="utilisateur"
                                    checked
                                    class="sr-only"
                                />
                                <div
                                    class="rounded-lg border-2 border-emerald-600 bg-white p-4 text-center transition hover:bg-emerald-50 has-[:checked]:bg-emerald-50 has-[:checked]:border-emerald-600"
                                >
                                    <p class="font-semibold text-emerald-700">
                                        Utilisateur
                                    </p>
                                    <p class="text-xs text-slate-600">
                                        Suivi personnel
                                    </p>
                                </div>
                            </label>

                            <label class="relative cursor-pointer">
                                <input
                                    type="radio"
                                    name="role"
                                    value="pro"
                                    class="sr-only"
                                />
                                <div
                                    class="rounded-lg border-2 border-slate-300 bg-white p-4 text-center transition hover:bg-slate-50 has-[:checked]:border-blue-600 has-[:checked]:bg-blue-50"
                                >
                                    <p class="font-semibold text-blue-600">
                                        Professionnel
                                    </p>
                                    <p class="text-xs text-slate-600">
                                        Partager expertise
                                    </p>
                                </div>
                            </label>
                        </div>
                    </div>

                    {/* ERROR MESSAGE */}
                    {
                        error && (
                            <div class="rounded-lg bg-red-50 p-3 text-sm text-red-600">
                                {error}
                            </div>
                        )
                    }

                    {/* SUBMIT BUTTON */}
                    <button
                        type="submit"
                        class="w-full rounded-lg bg-emerald-600 py-3 font-bold text-white transition hover:bg-emerald-700 active:scale-95"
                    >
                        Créer mon compte
                    </button>
                </form>
            </div>

            {/* LOGIN LINK */}
            <div class="text-center">
                <p class="text-sm text-slate-600">
                    Déjà un compte ?{" "}
                    <a
                        href="/authPassword"
                        class="font-semibold text-emerald-600 hover:text-emerald-700"
                    >
                        Connectez-vous
                    </a>
                </p>
            </div>
        </div>
    </section>
</Layout>
