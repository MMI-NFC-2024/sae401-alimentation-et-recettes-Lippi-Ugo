---
import type { AlimentResponse } from "../pocketbase-types";
import ImgPb from "./ImgPb.astro";

interface Props {
    aliment: AlimentResponse;
}

const { aliment } = Astro.props;
---

<a href={`/aliments/${aliment.id}`} class="block">
    <article
        class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg"
    >
        <ImgPb
            record={aliment}
            field="image"
            alt={aliment.nom}
            classPicture="h-44 w-full"
            classImg="h-44 w-full object-cover"
            thumb="800x400"
        />
        <div class="p-4">
            <h3 class="mb-3 text-lg font-semibold text-(--color-text-dark)">
                {aliment.nom}
            </h3>

            <div class="flex flex-wrap gap-2 mb-3">
                <span
                    class="inline-block px-2 py-1 rounded text-xs font-semibold bg-blue-100 text-blue-700"
                >
                    Protéines
                </span>
                <span
                    class="inline-block px-2 py-1 rounded text-xs font-semibold bg-orange-100 text-orange-700"
                >
                    Glucides
                </span>
                <span
                    class="inline-block px-2 py-1 rounded text-xs font-semibold bg-rose-100 text-rose-700"
                >
                    Lipides
                </span>
                <span
                    class="inline-block px-2 py-1 rounded text-xs font-semibold bg-violet-100 text-violet-700"
                >
                    Fibres
                </span>
            </div>

            <p class="text-sm text-(--color-text-muted)">
                {
                    aliment.calories_100g
                        ? `${aliment.calories_100g} kcal/100g`
                        : "Calories non renseignées"
                }
            </p>
        </div>
    </article>
</a>
