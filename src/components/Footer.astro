---
import Logo from "../assets/nutrirecette_logo.svg";
---

<footer class="bg-(--color-dark-bg) text-(--color-dark-text)">
    <div class="container mx-auto px-6 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
            <!-- Logo Section -->
            <div class="flex flex-col gap-4 md:col-span-1">
                <Logo class="w-32 h-auto" />
                <p class="text-sm leading-relaxed">
                    Votre guide complet pour une nutrition saine et équilibrée.
                </p>
            </div>

            <!-- Navigation Section -->
            <div>
                <h3 class="text-white font-semibold mb-4">Navigation</h3>
                <ul class="space-y-2 text-sm">
                    <li>
                        <a
                            href="/"
                            class="hover:text-(--color-primary) transition-colors"
                        >
                            Accueil
                        </a>
                    </li>
                    <li>
                        <a
                            href="/recettes"
                            class="hover:text-(--color-primary) transition-colors"
                        >
                            Recettes
                        </a>
                    </li>
                    <li>
                        <a
                            href="/regimes"
                            class="hover:text-(--color-primary) transition-colors"
                        >
                            Régimes
                        </a>
                    </li>
                    <li>
                        <a
                            href="/aliments"
                            class="hover:text-(--color-primary) transition-colors"
                        >
                            Aliments
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Legal Section -->
            <div>
                <h3 class="text-white font-semibold mb-4">Légal</h3>
                <ul class="space-y-2 text-sm">
                    <li>
                        <a
                            href="/mentions-legales"
                            class="hover:text-(--color-primary) transition-colors"
                        >
                            Mentions légales
                        </a>
                    </li>
                    <li>
                        <a
                            href="/politique-confidentialite"
                            class="hover:text-(--color-primary) transition-colors"
                        >
                            Politique de confidentialité
                        </a>
                    </li>
                    <li>
                        <a
                            href="/cgu"
                            class="hover:text-(--color-primary) transition-colors"
                        >
                            CGU
                        </a>
                    </li>
                    <li>
                        <a
                            href="/cgv"
                            class="hover:text-(--color-primary) transition-colors"
                        >
                            CGV
                        </a>
                    </li>
                    <li>
                        <a
                            href="/cookies"
                            class="hover:text-(--color-primary) transition-colors"
                        >
                            Cookies
                        </a>
                    </li>
                    <li>
                        <a
                            href="/divulgation-publicitaire"
                            class="hover:text-(--color-primary) transition-colors"
                        >
                            Divulgation publicitaire
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Contact Section -->
            <div>
                <h3 class="text-white font-semibold mb-4">Contact</h3>
                <p class="text-sm mb-4 leading-relaxed">
                    Des questions ? Contactez notre équipe de nutritionnistes.
                </p>
                <p class="text-xs leading-relaxed">
                    * Ce site contient des liens affiliés. Nous pouvons recevoir
                    une commission si vous effectuez un achat via ces liens.
                </p>
            </div>
        </div>

        <!-- Bottom Section -->
        <div class="border-t border-slate-700 pt-8 text-center">
            <p class="text-sm mb-2">
                © 2026 Nutri&Recettes. Tous droits réservés.
            </p>
            <p class="text-xs text-slate-400">
                Les informations fournies ne remplacent pas un avis médical
                professionnel.
            </p>
        </div>
    </div>
</footer>
