---
interface Props {
    recetteId: string;
    isFavorited?: boolean;
}

const { recetteId, isFavorited = false } = Astro.props;
---

<button
    class="favorite-btn"
    data-recette-id={recetteId}
    data-favorited={isFavorited}
    title={isFavorited ? "Retirer des favoris" : "Ajouter aux favoris"}
>
    <svg
        class="h-6 w-6"
        fill={isFavorited ? "currentColor" : "none"}
        stroke="currentColor"
        viewBox="0 0 24 24"
    >
        <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
        >
        </path>
    </svg>
</button>

<style>
    .favorite-btn {
        position: absolute;
        top: 12px;
        right: 12px;
        background: rgba(255, 255, 255, 0.9);
        border: none;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #ef4444;
        transition: all 0.2s ease;
    }

    .favorite-btn:hover {
        background: white;
        transform: scale(1.1);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    }

    .favorite-btn[data-favorited="true"] svg {
        fill: currentColor;
    }
</style>

<script>
    document.querySelectorAll(".favorite-btn").forEach((btn) => {
        btn.addEventListener("click", async (e) => {
            e.preventDefault();
            e.stopPropagation();

            const recetteId = btn.getAttribute("data-recette-id");
            const isFavorited = btn.getAttribute("data-favorited") === "true";

            try {
                const response = await fetch("/api/favoris", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                    },
                    body: JSON.stringify({
                        recetteId,
                        action: isFavorited ? "remove" : "add",
                    }),
                });

                if (response.ok) {
                    const newFavorited = !isFavorited;
                    btn.setAttribute("data-favorited", String(newFavorited));
                    (btn as HTMLButtonElement).title = newFavorited
                        ? "Retirer des favoris"
                        : "Ajouter aux favoris";
                }
            } catch (error) {
                console.error("Erreur favoris:", error);
            }
        });
    });
</script>
